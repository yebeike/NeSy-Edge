{
  "benchmark_id": "rq3_rebuild_v1_20260318",
  "thesis_alignment": {
    "rq3_claim": "Validate whether causally grounded edge-side evidence improves downstream cloud-side diagnosis and remediation under noisy incidents.",
    "llm_role": "Produce open-text diagnosis and repair rationale from noisy evidence.",
    "rag_role": "Provide unlabeled historical incident snippets as optional memory, not answer keys.",
    "graph_role": "Provide template-level causal cues and support paths without exposing family or action labels."
  },
  "prompt_contract": {
    "open_text_first": true,
    "forbid_closed_set_ids_in_prompt": true,
    "required_output_keys": [
      "diagnosis",
      "repair_action",
      "evidence_phrases"
    ],
    "forbid_family_action_descriptions": true
  },
  "method_budgets": {
    "reference_top_k": 3,
    "graph_top_k": 1,
    "rag_equals_agent_reference_budget": true,
    "agent_extra_signal": "graph_evidence_only"
  },
  "retrieval_policy": {
    "use_ground_truth_reference_filter": false,
    "use_ground_truth_reference_scoring": false,
    "use_ground_truth_action_for_leak_guard": true
  },
  "graph_selection": {
    "allow_without_refs": false,
    "require_reference_overlap": true,
    "use_ground_truth_hint_tokens": false,
    "query_source_weight": 1.2,
    "query_target_weight": 0.4,
    "reference_source_weight": 0.6,
    "reference_target_weight": 2.4,
    "edge_weight_bonus": 0.05,
    "summary_max_tokens_per_side": 5,
    "blocked_relations": [
      "symbolic_prior"
    ],
    "min_query_overlap": 1,
    "min_reference_overlap": 1,
    "min_score": 3.0
  },
  "noise_levels": [
    0.0,
    1.0
  ],
  "raw_window_rules": {
    "HDFS": {
      "before": 2,
      "after": 2,
      "max_chars": 700
    },
    "OpenStack": {
      "before": 2,
      "after": 2,
      "max_chars": 900
    },
    "Hadoop": {
      "before": 3,
      "after": 3,
      "max_chars": 1200
    }
  },
  "local_gate": {
    "heuristic_alert_max_family_accuracy": 0.45,
    "vanilla_open_max_family_accuracy_at_noise_1": 0.7,
    "agent_minus_rag_min_family_gap_at_noise_1": 0.05,
    "rag_minus_vanilla_min_family_gap_at_noise_1": 0.05,
    "min_rca_e2e_gap_rows": 2,
    "require_all_methods_non_flat": true
  }
}
